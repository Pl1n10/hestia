# Copy to .env and adjust. Everything is overridable via env (prefix HESTIA_).

# --- core ---
HESTIA_APP_NAME=Hestia
HESTIA_ENVIRONMENT=dev
HESTIA_DATABASE_URL=sqlite:///./hestia.db

# Active modules (plain comma-separated list; NOT JSON).
HESTIA_ENABLED_MODULES=dogs,subscriptions

# --- household ---
# Single-home deployments resolve agent/MCP writes to this household.
HESTIA_DEFAULT_HOUSEHOLD_ID=1

# --- auth ---
# dev    -> no auth, acts as the dev user (LOCAL ONLY)
# proxy  -> trust identity headers injected by Authentik / reverse proxy
# strict -> only Bearer agent tokens are accepted
HESTIA_AUTH_MODE=dev
HESTIA_DEV_USER_EMAIL=roberto@casa.local
HESTIA_DEV_USER_NAME=Roberto
HESTIA_PROXY_USER_HEADER=X-Authentik-Username
HESTIA_PROXY_EMAIL_HEADER=X-Authentik-Email

# Master agent token (quick path for Hermes). Leave empty to disable and use
# only revocable per-agent tokens from `python -m scripts.seed --token`.
HESTIA_AGENT_TOKEN=

# --- mcp (agent surface) ---
# stdio (local) | sse | streamable-http (behind a Cloudflare Tunnel)
HESTIA_MCP_TRANSPORT=stdio
HESTIA_MCP_HOST=127.0.0.1
# 8766 on the devbox so it doesn't collide with devbox-bridge (8765).
HESTIA_MCP_PORT=8766

# MCP auth + audit (HTTP transports only; stdio is a local pipe and skips these).
# require_auth -> reject MCP calls without a valid agent Bearer token.
HESTIA_MCP_REQUIRE_AUTH=true
HESTIA_MCP_AUDIT_ENABLED=true
HESTIA_MCP_AUDIT_LOG_PATH=./hestia-mcp-audit.log
HESTIA_MCP_AUDIT_MAX_BYTES=5000000
HESTIA_MCP_AUDIT_BACKUPS=5

# --- integrations (wired per-integration; stubs ship unconfigured) ---
HESTIA_GOOGLE_CLIENT_ID=
HESTIA_GOOGLE_CLIENT_SECRET=
HESTIA_BRING_EMAIL=
HESTIA_BRING_PASSWORD=
